# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Zoho Expense (leave blank to run in demo mode) ─────────────────────────
# Step 1: Register at https://api-console.zoho.com
# Step 2: Create a Self-Client with scopes:
#   ZohoExpense.orgsettings.READ,ZohoExpense.expensereports.READ,ZohoExpense.expenses.READ
# Step 3: Generate access token and paste below
VITE_ZOHO_TOKEN=
VITE_ZOHO_ORG_ID=

# ─── Claude AI (leave blank to run in demo mode) ─────────────────────────────
# Obtain an API key from https://console.anthropic.com
VITE_CLAUDE_API_KEY=
# Optional: override the default Claude model name
VITE_CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── App ────────────────────────────────────────────────────────────────────
# For Vercel deployment, add all of the above in:
# Vercel Dashboard → your project → Settings → Environment Variables
